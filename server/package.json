{
  "name": "mindease-server",
  "version": "1.0.0",
  "description": "Express server for MindEase wellness tracker",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "dependencies": {
    "@google/genai": "^0.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
